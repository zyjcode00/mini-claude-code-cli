# Mini Claude Code local configuration
# Copy this file to .env and fill in your real values.
# Never commit .env to Git.

# Required: API key for the OpenAI-compatible endpoint used by this project.
MINI_CLAUDE_API_KEY=your_api_key_here

# Optional: endpoint URL for your OpenAI-compatible provider.
# If omitted, the application uses https://api.openai.com/v1.
# Replace this placeholder with your own provider URL when needed.
MINI_CLAUDE_BASE_URL=https://api.example.com/v1

# Optional fallback supported by core.engine and main.py.
# OPENAI_API_KEY=your_openai_compatible_api_key_here
